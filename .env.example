# Supabase (port 6543 = Transaction Mode pooler for asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_JWT_SECRET=your-jwt-secret-here

# OpenAI (not used until Phase 2)
OPENAI_API_KEY=sk-...

# Redis (not used until Phase 3)
REDIS_URL=redis://localhost:6379/0

# App
DEFAULT_CLIENT_ID=00000000-0000-0000-0000-000000000001
CORS_ORIGINS=http://localhost:3000

# Next.js (browser-safe vars)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
NEXT_PUBLIC_API_URL=http://localhost:8000
